# This env file uses @env-spec - see https://varlock.dev/env-spec for more info
#
# @defaultRequired=infer @defaultSensitive=false
# @generateTypes(lang=ts, path=env.d.ts)
# ----------

# Server port
# @required=false
PORT=3000

# Comma-separated list of allowed CORS origins
# @required=false @example="http://localhost:3001,https://yourapp.com"
ALLOWED_ORIGINS=""

# AI provider — fal | openai (default: fal)
# @required=false
AI_PROVIDER=fal

# API key for the active image generation provider
# @required @sensitive @example="sk-..."
IMAGE_API_KEY=""

# Google OAuth — CAT-5
# @required @sensitive @example="123456789.apps.googleusercontent.com"
GOOGLE_CLIENT_ID=""

# @required @sensitive @example="GOCSPX-..."
GOOGLE_CLIENT_SECRET=""

# Restrict sign-in to this Google Workspace domain
# @required=false @example="yourcompany.com"
GOOGLE_ALLOWED_DOMAIN=""

# JWT / session signing secret — use a long random string
# @required @sensitive @example="change_this_to_a_long_random_string"
SESSION_SECRET=""

# Figma personal access token — CAT-11
# @required @sensitive @example="figd_..."
FIGMA_ACCESS_TOKEN=""

# Key of the Figma file to upload generated images into
# @required @example="aBcDeFgHiJkL"
FIGMA_FILE_KEY=""
